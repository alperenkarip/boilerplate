<?xml version="1.0" encoding="UTF-8"?>
<!--
  PLACEHOLDER — gercek dosya degildir. Firebase Console > Project Settings > iOS app
  uzerinden GoogleService-Info.plist indirin, bu dosyayi 'GoogleService-Info.plist'
  olarak kopyalayip asagidaki PLACEHOLDER degerleri gercek degerlerle degistirin.
  Gercek dosya .gitignore'dadir ve commit edilmez (ADR-020).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>PLACEHOLDER_IOS_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>PLACEHOLDER_PROJECT_NUMBER</string>
	<key>BUNDLE_ID</key>
	<string>com.project.boilerplate</string>
	<key>PROJECT_ID</key>
	<string>PLACEHOLDER_PROJECT_ID</string>
	<key>STORAGE_BUCKET</key>
	<string>PLACEHOLDER_PROJECT_ID.appspot.com</string>
	<key>GOOGLE_APP_ID</key>
	<string>PLACEHOLDER_IOS_GOOGLE_APP_ID</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
</dict>
</plist>
