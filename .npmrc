# pnpm guvenlik baseline (A.1.7, ADR-003)
# Yeni paketlerin en az 3 gun yayinlanmis olmasi gerekir
minimum-release-age=3d

# Canonical paketler icin release-age muafiyeti
minimumReleaseAgeExclude[]=zod
minimumReleaseAgeExclude[]=react-hook-form

# Native build script'lerini engelleyen allow-builds politikasi
# Sadece bilinen guvenli paketler build calistirabilir
onlyBuiltDependencies[]=esbuild
onlyBuiltDependencies[]=@swc/core
