{
  "name": "@project/functions",
  "version": "0.0.0",
  "private": true,
  "description": "Cloud Functions for Firebase — canonical write path and server logic (ADR-020).",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "serve": "pnpm build && firebase emulators:start --only functions",
    "shell": "pnpm build && firebase functions:shell",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "eslint": "^9.0.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.0.0"
  }
}
