# Uygulama
VITE_APP_NAME=Boilerplate
VITE_APP_VERSION=0.0.0

# Firebase (ADR-020 / ADR-021) — canonical backend, data (Firestore) ve auth platformu
# Degerler: Firebase Console -> Project Settings -> General -> Your apps -> SDK setup and configuration
# NOT: ADR-020 ile generic REST API katmani yoktur. Yazma yolu callable Cloud Functions uzerinden,
#      okuma client SDK ile dogrudan Firestore'dan yapilir; bu nedenle eski VITE_API_BASE_URL kaldirilmistir.

# Web (firebase JS SDK v11.x)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Mobil (@react-native-firebase)
# Native yapilandirma normalde google-services.json (Android) ve GoogleService-Info.plist (iOS)
# ile gelir; asagidaki EXPO_PUBLIC_* degiskenleri JS tarafinin okudugu esleniklerdir.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Cloud Functions ve Emulator (ADR-020)
# Local gelistirme/test Firebase Emulator Suite uzerinde kosar (gercek projeye baglanmaz).
# true yapilirsa web/mobil adapter Auth/Firestore/Functions emulator'larina baglanir.
VITE_FIREBASE_USE_EMULATOR=false
EXPO_PUBLIC_FIREBASE_USE_EMULATOR=false
VITE_FIREBASE_EMULATOR_HOST=localhost
EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=localhost
# Admin SDK (seed scriptleri, functions deploy) icin service account anahtar dosyasi yolu.
# ASLA commit edilmez; gercek deger .env (gitignore'lu) icinde tutulur.
GOOGLE_APPLICATION_CREDENTIALS=

# Sentry (ADR-009)
# DSN almak icin: https://sentry.io → Proje ayarlari → Client Keys
VITE_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=

# Analytics (ADR-009)
# Vendor secimi yapildiktan sonra ilgili API key girilir
VITE_ANALYTICS_KEY=
EXPO_PUBLIC_ANALYTICS_KEY=

# Deep Linking (ADR-014)
# Universal Links ve App Links icin kullanilacak domain
VITE_DEEP_LINK_DOMAIN=example.com
EXPO_PUBLIC_DEEP_LINK_DOMAIN=example.com

# EAS Update (ADR-015)
# Expo project ID: eas init ile alinir
EXPO_PUBLIC_EAS_PROJECT_ID=

# Push Notification (ADR-013)
# Firebase Cloud Messaging sender ID (VITE_FIREBASE_MESSAGING_SENDER_ID ile ayni degerdir)
EXPO_PUBLIC_FCM_SENDER_ID=

# In-App Purchase (ADR-016)
# RevenueCat API key: https://app.revenuecat.com
EXPO_PUBLIC_REVENUECAT_API_KEY=

# Privacy/Compliance (ADR-017)
VITE_PRIVACY_POLICY_URL=
VITE_TERMS_OF_SERVICE_URL=
