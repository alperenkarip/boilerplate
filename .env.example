# Uygulama
VITE_APP_NAME=Boilerplate
VITE_APP_VERSION=0.0.0

# API
VITE_API_BASE_URL=http://localhost:3000/api

# Sentry (ADR-009)
# DSN almak icin: https://sentry.io → Proje ayarlari → Client Keys
VITE_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=

# Analytics (ADR-009)
# Vendor secimi yapildiktan sonra ilgili API key girilir
VITE_ANALYTICS_KEY=
EXPO_PUBLIC_ANALYTICS_KEY=

# Deep Linking (ADR-014)
# Universal Links ve App Links icin kullanilacak domain
VITE_DEEP_LINK_DOMAIN=example.com
EXPO_PUBLIC_DEEP_LINK_DOMAIN=example.com

# EAS Update (ADR-015)
# Expo project ID: eas init ile alinir
EXPO_PUBLIC_EAS_PROJECT_ID=

# Push Notification (ADR-013)
# Firebase Cloud Messaging sender ID
EXPO_PUBLIC_FCM_SENDER_ID=

# In-App Purchase (ADR-016)
# RevenueCat API key: https://app.revenuecat.com
EXPO_PUBLIC_REVENUECAT_API_KEY=

# Privacy/Compliance (ADR-017)
VITE_PRIVACY_POLICY_URL=
VITE_TERMS_OF_SERVICE_URL=
